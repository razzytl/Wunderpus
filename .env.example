# Wunderpus Environment Variables Configuration
# Copy this file to .env and fill in your values

# --- LLM Provider API Keys ---
WONDERPUS_OPENAI_API_KEY=sk-...
WONDERPUS_ANTHROPIC_API_KEY=sk-ant-...
WONDERPUS_GEMINI_API_KEY=AIza...

# --- Provider Settings ---
WONDERPUS_DEFAULT_PROVIDER=openai
WONDERPUS_OLLAMA_HOST=http://localhost:11434

# --- Security & Core ---
# Generate a 32-byte base64 key for encryption: openssl rand -base64 32
WONDERPUS_ENCRYPTION_KEY=
WONDERPUS_LOG_LEVEL=info

# --- Channel Integration ---
# Telegram Bot Token
WONDERPUS_TELEGRAM_TOKEN=
# Discord Bot Token
WONDERPUS_DISCORD_TOKEN=

# --- Heartbeat (Periodic Tasks) ---
WUNDERPUS_HEARTBEAT_ENABLED=true
WUNDERPUS_HEARTBEAT_INTERVAL=30
